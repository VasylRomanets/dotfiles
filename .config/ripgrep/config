# Search hidden files and directories (e.g. dotfiles) by default
--hidden

# Case-insensitive search, unless the pattern contains uppercase letters
--smart-case

# Truncate long lines in the output and show a preview instead of hiding them
--max-columns=150
--max-columns-preview

# Skip files larger than 5MB (binary blobs, build artifacts, etc.)
--max-filesize=5M

# Remove the colon separator between line numbers and matched content
--field-match-separator=

# Exclude version control
--glob=!.git

# Exclude dependency lock files
--glob=!package-lock.json

# Exclude environment files (may contain secrets)
--glob=!.env
--glob=!.env.*

# Everforest Dark Hard color theme
--colors=path:fg:0xa7,0xc0,0x80
--colors=path:style:bold
--colors=line:fg:0x85,0x92,0x89
--colors=line:style:nobold
--colors=match:fg:0xdb,0xbc,0x7f
--colors=match:bg:0x2e,0x38,0x3c
--colors=match:style:bold

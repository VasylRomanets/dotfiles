[include]
  path = ~/.config/git/config.local

[init]
  defaultBranch = main

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[fetch]
  prune = true

[push]
  autoSetupRemote = true

[merge]
  conflictStyle = zdiff3

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers

[commit]
  gpgSign = true

[tag]
  gpgSign = true

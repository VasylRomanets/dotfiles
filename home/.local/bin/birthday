#!/bin/bash

# My friend Alex created this to congratulate me on my birthday.
# It was very sweet and I decided to keep it here so I don't lose it.
# Author: Alex Leontyev
# Created: 2026-06-15

# Colors
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' 

clear

# Init
echo -e "${GREEN}Initiating Birthday Sequence v2.0...${NC}"
sleep 1.5
echo ""

echo "Dear Friend,"
sleep 1.5

echo "We wish you long hours of riding a leaping deer!"
sleep 1.5

echo "Put your opponents in zugzwang!"
sleep 1.5

echo "Happines and Health!"
sleep 1.5

echo -e "Stay Safe! ${RED}❤️${NC}"
sleep 1.5

# Scanning
echo -e "${YELLOW}Running system diagnostics...${NC}"
sleep 1.5
echo -n "Scanning for bad vibes... "
sleep 2
echo -e "${GREEN}[0 FOUND. ALL CLEAR]${NC}"
sleep 1.5

# Spider removal task
echo -n "Removing giant black spiders from your path... "
sleep 2
echo -e "${GREEN}[DONE]${NC}"
sleep 1.5
echo ""

# Age update
echo -n "Updating life stats... "
sleep 2
echo -e "${GREEN}[DONE]${NC}"
sleep 1

echo -e "${GREEN}> SUCCESS: +1 year of experience successfully credited to your account.${NC}"
sleep 2

# Back pain issues
echo ""
echo -e "${RED}WARNING: Back pain probability increased by 10%. Proceed with caution!${NC}"
sleep 2.5

# ASCII Cake
echo ""
echo -e "${YELLOW}   ,,,,,   ${NC}"
echo -e "${YELLOW}  _|||||_  ${NC}"
echo -e "${NC} {~~~~~~~} ${NC}"
echo -e "${NC} { Happy } ${NC}"
echo -e "${NC} { B-day!} ${NC}"
echo -e "${NC} ~~~~~~~~~ ${NC}"
echo ""

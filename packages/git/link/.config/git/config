[include]
  path = ~/.config/git/config.local

[init]
  defaultBranch = main

[core]
  pager = delta
  quotepath = false

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[fetch]
  prune = true

[push]
  autoSetupRemote = true

[merge]
  conflictStyle = zdiff3

[diff]
  colorMoved = default

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers

[commit]
  gpgSign = true

[tag]
  gpgSign = true

[help]
  autocorrect = prompt

[alias]
  a = add
  b = branch
  c = commit
  co = checkout
  d = diff
  f = fetch
  l = log --oneline --graph --decorate
  lp = log --graph --pretty=format:'%C(yellow)%h%Creset -%C(magenta)%d%Creset %s %C(green)(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  p = push
  pu = pull
  s = status
  ss = status -s
  st = stash
